# Copy to ".env" and fill in. Do NOT commit your real .env.

# Required: the LLM API key (read from the environment, never hardcoded).
# Use OPENAI_API_KEY for OpenAI, or OPENROUTER_API_KEY for OpenRouter -- either
# name is accepted. Set just one.
OPENAI_API_KEY=sk-...your-openai-key...
# OPENROUTER_API_KEY=sk-or-...your-openrouter-key...

# LLM endpoint. Leave unset for OpenAI's default. Point it at any
# OpenAI-compatible gateway to use a different provider -- e.g. OpenRouter:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional OpenRouter ranking headers (only sent if set). See
# https://openrouter.ai/docs/api-reference/overview#headers
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_X_TITLE=Meridian Pay demo

# Admin password for the dashboard. If you leave this unset, a random one is
# generated and printed to the server console at startup.
# AGENT_ADMIN_PASSWORD=choose-a-strong-password

# Target bearer token (what Lakera Red sends). If unset, one is generated at
# startup and shown in the dashboard. You can also regenerate it from the UI.
# AGENT_AUTH_TOKEN=some-long-random-token

# Optional. The model id to call. For OpenAI use a bare id (e.g. gpt-4o-mini);
# for OpenRouter use the namespaced form (e.g. openai/gpt-4o-mini,
# anthropic/claude-3.5-sonnet). See https://openrouter.ai/models
AGENT_MODEL=gpt-4o-mini
# AGENT_HOST=127.0.0.1
# AGENT_PORT=8000

# The decoy code, system prompt and refusal phrases are no longer environment
# variables -- edit them live in the dashboard ("Target configuration"). They are
# held in memory only and reset to defaults on restart.

# Set true when serving over HTTPS (e.g. behind a tunnel) so the session
# cookie is marked Secure.
# AGENT_COOKIE_SECURE=true

# Local-only escape hatch: disables target-endpoint auth entirely. Leave UNSET
# for any shared/hosted/tunnelled demo.
# AGENT_ALLOW_NO_AUTH=true

# Optional: only set if your model supports a custom sampling temperature.
# Newer reasoning models reject non-default values, so it is omitted by default.
# AGENT_TEMPERATURE=0.7

